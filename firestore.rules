rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin check uses the verified email claim from Google sign-in — this
    // is server-enforced (unlike the client-side ADMIN_EMAILS list in
    // src/config/admin.js, which only controls what the UI shows/hides).
    // Add more admins here AND in src/config/admin.js.
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'berndvh015@gmail.com';
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admin can read (not write) any profile, e.g. for a user-count stat
      // on the Admin page. Ledger data stays owner-only either way.
      allow read: if isAdmin();

      match /ledgerEntries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /monthlyCycles/{cycleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Global app config (currently just { maintenanceMode }). Readable by
    // everyone, including signed-out visitors, so the maintenance screen
    // can show correctly before anyone logs in. Only the admin can write.
    match /app_config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
